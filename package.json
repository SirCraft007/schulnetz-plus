{
  "name": "schulnetz-extention",
  "version": "0.2.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "sync:version": "tsx scripts/sync-version.ts",
    "predev": "pnpm sync:version",
    "dev": "vite build --watch",
    "prebuild": "pnpm sync:version",
    "prepack": "pnpm sync:version",
    "build": "vite build",
    "lint": "pnpm build && pnpm dlx web-ext lint --source-dir dist",
    "xpi": "pnpm build && pnpm dlx web-ext build --source-dir dist --artifacts-dir . --filename schulnetz-plus-{version}.xpi --overwrite-dest",
    "xpi:sign": "pnpm build && pnpm dlx web-ext sign --source-dir dist --artifacts-dir . --channel unlisted --api-key \"$AMO_JWT_ISSUER\" --api-secret \"$AMO_JWT_SECRET\"",
    "xpi:release": "pnpm xpi && pnpm xpi:sign"
  },
  "keywords": [],
  "author": "",
